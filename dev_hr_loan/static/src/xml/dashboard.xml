                        <div class="card-title text-center p-3" style="font-weight:600; font-size:23px;">
                            <div class="row">
                                <div class="col-10">Employee Installment </div>
                                <div class="col-2"><i class="fa fa-download" style="cursor: pointer;" aria-hidden="true" t-on-click="(e) => this._downloadChart(e)"/></div>
                            </div>
                        </div>

                        <div class="card-body text-center">
                            <canvas id="loan_by_hr" style="height:200px; max-height:400px;"/>
                        </div>
                    </div>
                </div>
                <div class="col-lg-6 col-md-6 col-12">
                    <div class="card table-card" style="overflow-x:clip;">
