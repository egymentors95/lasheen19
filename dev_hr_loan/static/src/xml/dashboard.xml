    </t>

    <t t-name="loan_tables">
        <div class="row mt-4 gy-2 md-5">
            <div class='col-lg-12 col-md-4 col-12'>
                    <div class="card table-card">
                        <div class="card-header table-header">
                            <span>
                               Loan Request
                            </span>
                        </div>
                        <table id="employee_loan_list" class="table table-hover">
                            <thead>
                                <tr>
                                    <th>Number</th>
                                    <th>Employee</th>
                                    <th>Job Position</th>
                                    <th>Amount</th>
                                    <th>Type</th>
                                    <th>Term</th>
                                    <th>Rate</th>
                                    <th>Date</th>
                                </tr>
                            </thead>
                            <tbody> </tbody>
                            <tr>
                                <td> </td>
                                <td> </td>
                                <td> </td>
                                <td>
                                <button id='prev_button' disabled="1" t-on-click="(e) => this.prevPage(e)">
                                    Previous
                                </button>
                                </td>
                                <td>
                                <button id = 'next_button' t-on-click="(e) => this.nextPage(e)" >Next</button>
                                </td>
                            </tr>
                        </table>
                    </div>
                </div>

        </div>
        <div class="row">
            <div class="col-12" style="margin:20px;"> </div>
        </div>
        </t>
</templates>