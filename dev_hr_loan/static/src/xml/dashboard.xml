                            <div class="row">
                                     <div class="col-10">Loan Type</div>
                                    <div class="col-2"><i class="fa fa-download" style="cursor: pointer;" aria-hidden="true" t-on-click="(e) => this._downloadChart(e)"/></div>
                            </div>
                        </div>
                        <div class="card-body text-center">
                            <canvas id="loan_amount_chart_data" class="bar-chart"/>
                        </div>
                    </div>
                </div>

                 <div class="col-lg-6 col-md-6 col-12">
                    <div class="card table-card" style="overflow-x:clip;">
