<?xml version="1.0" encoding="UTF-8"?>

<templates id="loanDashboard" xml:space="preserve">
    <t t-name="loanDashboard">
        <!-- <div style=" max-height: -webkit-fill-available; overflow-y: scroll; background-color:#fbf8fa"> -->
        <div class="gridstack-wrapper" style="background-color:#fff7fd">
            <div class="mx-5">
                <div class="row gx-0 mt-3">
                    <div class="col-12 d-flex justify-content-end">
                        <button id="downloadBtn" t-on-click="(e) => this.downloadReport(e)" class="btn btn-primary p-2">
                            <i class="fa fa-file-pdf-o p-1" aria-hidden="true"/>
                            Print
                        </button>
                    </div>
                </div>
            </div>
            <div class="mx-5 " id="dashboard">
                <t t-call="loan_filters"/>
                <t t-call="loan_counters"/>
                <t t-call="loan_charts"/>
                <t t-call="loan_tables" />
            </div>
        </div>
    </t>
    <t t-name="loan_filters">
        <div class="card mt-4 filters">
            <div class="row p-2 m-2 gx-0 gy-2" >
                <div class="col-lg-1 d-flex my-auto justify-content-center">
                    <img t-att-src="'data:image/png;base64,' + user_img" class="css-shadow"/>
                </div>
                <div class="col-lg-4 pl-1 my-auto">
                    <h2><b> <t t-esc="greetings"/>, <t t-esc="user_name"/>.</b></h2>
                    <h4>Welcome to your HR Loan Dashboard.</h4>
                </div>
                <div class="col-lg-7">
                    <div class="row gy-2">
                        <div class="col-lg-3 m-0">
                            <label for="loan_users_selection" class="form-label fw-bolder">Users</label>
                            <select class="form-select" id="loan_users_selection"
                                    t-on-change="(ev) => this._onchangeFilter(ev)">
                                <option value="all"> All Users</option>
                            </select>
                        </div>
                        <div class="col-lg-3 m-0">
                             <label for="hr_selection" class="form-label fw-bolder">HR </label>
                            <select class="form-select" id="hr_selection"
                                    t-on-change="(ev) => this._onchangeFilter(ev)">
                                <option value="all">All Employee</option>
                            </select>
                        </div>
                         <div class="col-lg-3 m-0">
                             <label for="loan_type_selection" class="form-label fw-bolder">Loan Type</label>
                            <select class="form-select" id="loan_type_selection"
                                    t-on-change="(ev) => this._onchangeFilter(ev)">
                                <option value="all"> All Loan Type</option>
                            </select>
                        </div>
                        <div class="col-lg-3 m-0">
                             <label for="duration_selection" class="form-label fw-bolder">Date </label>
                            <select class="form-select" id="duration_selection"
                                    t-on-change="(ev) => this._onchangeFilter(ev)">
                                <option value="0">Today</option>
                                <option value="7">Last 7 Days</option>
                                <option value="28">Last 28 Days</option>
                                <option value="90">Last 90 Days</option>
                                <option value="365">Last 365 Days</option>
                                <option value="all">Lifetime</option>
                            </select>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </t>

    <t t-name="loan_counters">
        <div class="mt-5 mb-5">
            <div class="row text-center gy-2">
                <div class="col-lg-2">
                    <div class="row mt-2">
                        <div class="col-12">
                            <div class="card box" id='draft_lst1' t-on-click="(e) => this.action_all_loan(e)">
                                <div class="card-body box-body" >
                                    <h1 id="draft_lst">
                                        <t t-esc="draft_lst.length"/>
                                    </h1>
                                    <h5>Draft</h5>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-lg-2">
                    <div class="row mt-2">
                        <div class="col-12">
                            <div class="card box" id="submit_request_lst1" t-on-click="(e) => this.action_all_loan(e)">
                                <div class="card-body box-body">
                                    <h1 id="submit_request_lst">
                                        <t t-esc="submit_request_lst.length"/>
                                    </h1>
                                    <h5>Submit Request</h5>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-lg-2">
                    <div class="row mt-2">
                        <div class="col-12">
                            <div class="card box" id ="department_approve_lst1" t-on-click="(e) => this.action_all_loan(e)">
                                <div class="card-body box-body">
                                    <h1 id="department_approve_lst">
                                        <t t-esc="department_approve_lst.length"/>
                                    </h1>
                                    <h5>Department Approval</h5>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-lg-2">
                    <div class="row mt-2">
                        <div class="col-12">
                            <div class="card box" id="paid_loan_lst1" t-on-click="(e) => this.action_all_loan(e)">
                                <div class="card-body box-body">
                                    <h1 id="paid_loan_lst">
                                        <t t-esc="paid_loan_lst.length"/>
                                    </h1>
                                    <h5> Approve</h5>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-lg-2">
                    <div class="row mt-2">
                        <div class="col-12">
                            <div class="card box" id="done_lst1" t-on-click="(e) => this.action_all_loan(e)">
                                <div class="card-body box-body">
                                        <h1 id="done_lst">
                                            <t t-esc="done_lst.length"/>
                                        </h1>
                                    <h5>Done</h5>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-lg-2">
                    <div class="row mt-2">
                        <div class="col-12">
                            <div class="card box" id="close_lst1" t-on-click="(e) => this.action_all_loan(e)">
                                <div class="card-body box-body">
                                        <h1 id="close_lst">
                                            <t t-esc="close_lst.length"/>
                                        </h1>
                                    <h5>Close</h5>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </t>

    <t t-name="loan_charts">
        <div class="mt-5" >
            <div class="row gy-2" >
                <div class="col-lg-12 col-md-6 col-12">
