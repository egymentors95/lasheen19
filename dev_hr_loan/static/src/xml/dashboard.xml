                            <div class="row">
                                     <div class="col-10"> Employee Loan</div>
                                    <div class="col-2"><i class="fa fa-download" style="cursor: pointer;" aria-hidden="true" t-on-click="(e) => this._downloadChart(e)"/></div>
                            </div>
                        </div>
                        <div class="card-body text-center">
                            <canvas id="hr_loan_chart_data" class="bar-chart"/>
